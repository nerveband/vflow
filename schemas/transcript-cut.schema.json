{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "transcript cut",
  "type": "object",
  "required": ["version", "segments"],
  "properties": {
    "version": {
      "const": "vflow-transcript-cut/v1"
    },
    "summary": {
      "type": "string"
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string"
          },
          "source_id": {
            "type": "string"
          },
          "start_seconds": {
            "type": "number",
            "minimum": 0
          },
          "end_seconds": {
            "type": "number",
            "minimum": 0
          },
          "transcript_start_seconds": {
            "type": "number",
            "minimum": 0
          },
          "transcript_end_seconds": {
            "type": "number",
            "minimum": 0
          },
          "transcript_start": {
            "type": "string"
          },
          "transcript_end": {
            "type": "string"
          },
          "speaker": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "source_timeline_offset": {
            "type": "number"
          },
          "reference_start_seconds": {
            "type": "number",
            "minimum": 0
          },
          "reference_end_seconds": {
            "type": "number",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
