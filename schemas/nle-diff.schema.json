{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "vflow NLE diff",
  "type": "object",
  "required": ["version", "status", "import", "format", "safe_merge", "needs_review", "blocked", "unclassified"],
  "properties": {
    "version": {
      "const": "vflow-nle-diff/v1"
    },
    "status": {
      "const": "classified"
    },
    "import": {
      "type": "string"
    },
    "format": {
      "type": "string",
      "enum": ["edl", "fcpxml", "resolve", "premiere", "otio", "mlt", "unknown"]
    },
    "artifact": {
      "type": "string"
    },
    "safe_merge": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/change"
      }
    },
    "needs_review": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/change"
      }
    },
    "blocked": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/change"
      }
    },
    "unclassified": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/change"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "change": {
      "type": "object",
      "required": ["id", "type", "description", "confidence"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "segment_id": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    }
  }
}
