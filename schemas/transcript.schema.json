{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "transcript words",
  "type": "object",
  "required": ["version", "source_media_id", "rate", "words"],
  "properties": {
    "version": {
      "const": "vflow-words/v1"
    },
    "source_media_id": {
      "type": "string",
      "minLength": 1
    },
    "rate": {
      "type": "string",
      "minLength": 1
    },
    "words": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "text",
          "start_frame",
          "end_frame",
          "provider"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "speaker_label": {
            "type": "string"
          },
          "start_frame": {
            "type": "integer",
            "minimum": 0
          },
          "end_frame": {
            "type": "integer",
            "minimum": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "provider": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
