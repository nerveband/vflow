{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "content EDL",
  "type": "object",
  "required": ["version", "rate", "delete_segments"],
  "properties": {
    "version": {
      "const": "vflow-content-edl/v1"
    },
    "rate": {
      "type": "string",
      "minLength": 1
    },
    "delete_segments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "start_frame",
          "end_frame",
          "reason",
          "confidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "start_frame": {
            "type": "integer",
            "minimum": 0
          },
          "end_frame": {
            "type": "integer",
            "minimum": 1
          },
          "reason": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "source_start_seconds": {
            "type": "number",
            "minimum": 0
          },
          "source_end_seconds": {
            "type": "number",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
